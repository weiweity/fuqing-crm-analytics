#!/bin/bash
# Sprint 30.2 soft WARN (CHANGELOG 跟随 hard block → soft WARN)
# Sprint 178+: hooksPath 保护 (防止 pytest 修改 core.hooksPath 指向 tmp dir)
# Finish 2026-07-19: light path when no code staged
EXPECTED_HOOKS_PATH="$(git rev-parse --show-toplevel)/.githooks"
CURRENT_HOOKS_PATH="$(git config core.hooksPath)"
if [ -z "$CURRENT_HOOKS_PATH" ]; then
    echo "⚠️  core.hooksPath 未设置, 自动激活 .githooks"
    git config core.hooksPath .githooks
elif [ "$CURRENT_HOOKS_PATH" != "$EXPECTED_HOOKS_PATH" ]; then
    echo "⚠️  core.hooksPath 被改: $CURRENT_HOOKS_PATH"
    echo "   期望: $EXPECTED_HOOKS_PATH (pytest tmp dir 污染常见)"
    echo "   自动恢复..."
    git config --unset core.hooksPath
    git config core.hooksPath .githooks
fi

# Pre-commit hook: CHANGELOG 跟随 + bare except + scoped heavy checks
# Install: git config core.hooksPath .githooks

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_PY=$(echo "$STAGED" | grep -E '\.py$|docs/|\.md$' || true)
STAGED_CHANGELOG=$(echo "$STAGED" | grep '^CHANGELOG\.md$' || true)

if [ -n "$STAGED_PY" ] && [ -z "$STAGED_CHANGELOG" ]; then
    if [ "${STRICT_CHANGELOG_HOOK:-0}" = "1" ]; then
        echo "❌ CHANGELOG.md 未跟随 commit (STRICT_CHANGELOG_HOOK=1 模式)"
        echo "   修复: git add CHANGELOG.md 同步加版本号条目"
        exit 1
    else
        echo "💡 建议同步更新 CHANGELOG.md (改 $(echo "$STAGED_PY" | wc -l | tr -d ' ') 个 .py/docs/.md 文件)"
    fi
fi

# Light path: docs/md/config only → skip heavy py/vue linters
STAGED_CODE=$(echo "$STAGED" | grep -E '\.(py|vue|ts|tsx|js)$|^\.githooks/|^backend/|^scripts/|^frontend-vue3/' || true)
if [ -z "$STAGED_CODE" ]; then
    echo "✅ pre-commit light path (no code staged — docs/config only)"
    exit 0
fi

# 禁止 bare except (Sprint 33 L4.x)
STAGED_PY_FILES=$(echo "$STAGED" | grep '\.py$' || true)
if [ -n "$STAGED_PY_FILES" ]; then
    if grep -nE '^\s*except\s*:\s*$' $STAGED_PY_FILES 2>/dev/null; then
        echo "❌ bare except 不允许 (Sprint 33 L4.x 实战 fix 模式)"
        echo "   修复: except Exception as e: 显式异常类型"
        exit 1
    fi
fi

# Sprint 18 #142 contracts/_lint
STAGED_CONTRACTS=$(echo "$STAGED" | grep -E '^backend/contracts/.*\.py$' || true)
if [ -n "$STAGED_CONTRACTS" ]; then
    if ! python3 -m backend.contracts._lint 2>&1 | tail -3; then
        echo "❌ contracts lint 失败"
        exit 1
    fi
fi

# import / test-order only when Python or githooks staged
if [ -n "$STAGED_PY_FILES" ] || echo "$STAGED" | grep -q '^\.githooks/'; then
    if [ -x ".githooks/check_imports.py" ]; then
        if ! python3 .githooks/check_imports.py 2>&1 | tail -3; then
            echo "❌ check_imports.py 失败"
            exit 1
        fi
    fi
    if [ -x ".githooks/check_test_order.py" ]; then
        if ! python3 .githooks/check_test_order.py 2>&1 | tail -3; then
            echo "❌ check_test_order.py 失败"
            exit 1
        fi
    fi
fi
if [ -x ".githooks/check_review_ground_truth.py" ]; then
    if ! python3 .githooks/check_review_ground_truth.py 2>&1 | tail -3; then
        echo "❌ check_review_ground_truth.py 失败"
        exit 1
    fi
fi

# L4.91 Excel SSOT when vue/ts staged
if [ -f "backend/scripts/check_l4_91_excel_export_ssot.py" ]; then
    STAGED_VUE=$(echo "$STAGED" | grep -E '\.vue$|\.ts$' || true)
    if [ -n "$STAGED_VUE" ]; then
        if ! python3 backend/scripts/check_l4_91_excel_export_ssot.py 2>&1 | tail -10; then
            echo "❌ L4.91 Excel 导出 SSOT lint 失败"
            exit 1
        fi
    fi
fi

# warn on huge tmp duckdb orphans (fail-open)
python3 -c "
import os
try:
    files = []
    for d in ['/private/tmp', '/tmp']:
        if os.path.exists(d):
            for f in os.listdir(d):
                if f.startswith(('fuqing_crm_', 'pytest-of-')) and f.endswith('.duckdb'):
                    p = os.path.join(d, f)
                    try:
                        if os.path.getsize(p) > 5 * 1024**3:
                            files.append(p)
                    except Exception:
                        pass
    if files:
        print(f'⚠️  发现 {len(files)} 个 >5GB duckdb 孤儿 (Sprint 6 P0-3)')
except Exception:
    pass
" 2>&1 || true

echo "✅ pre-commit 检查通过"
exit 0
