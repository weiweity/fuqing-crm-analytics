#!/bin/bash
# Pre-commit hook: ruff lint + CHANGELOG 跟随 + 禁止 bare except
# Install: git config core.hooksPath .githooks

# P2 散点: CHANGELOG.md 跟随 — 改 .py / docs/ 时建议同步改 CHANGELOG.md
# Sprint 30.2 (v0.4.14.106): hard block → soft WARN.
# 原因: feature branch 多次 commit 时, 每次都强制 CHANGELOG 跟随不实际
#       (应该合并后 1 次写 CHANGELOG). Post-merge hint 移到
#       .githooks/post-merge, 跑 `git log <last-tag>..HEAD` 校验.
# 紧急回切 hard block: STRICT_CHANGELOG_HOOK=1 git commit ...
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_PY=$(echo "$STAGED" | grep -E '\.py$|docs/|\.md$' || true)
STAGED_CHANGELOG=$(echo "$STAGED" | grep '^CHANGELOG\.md$' || true)

if [ -n "$STAGED_PY" ] && [ -z "$STAGED_CHANGELOG" ]; then
    if [ "${STRICT_CHANGELOG_HOOK:-0}" = "1" ]; then
        echo "❌ CHANGELOG.md 未跟随 commit (STRICT_CHANGELOG_HOOK=1 模式)"
        echo "   修改了 $(echo "$STAGED_PY" | wc -l | tr -d ' ') 个文件但 CHANGELOG.md 未变更"
        echo "   修复: git add CHANGELOG.md 同步加版本号条目"
        exit 1
    fi
    echo "⚠️  CHANGELOG.md 未跟随 commit (Sprint 30.2 soft WARN 模式)"
    echo "   修改了 $(echo "$STAGED_PY" | wc -l | tr -d ' ') 个文件但 CHANGELOG.md 未变更"
    echo "   建议: 合并前补 CHANGELOG.md 版本号条目 (post-merge hook 也会再提醒一次)"
    echo "   例外: 纯 docs/ 改动 / hotfix 紧急可忽略"
    # 不阻断 (Sprint 30.2 之前为 exit 1, --no-verify 绕过是反 pattern)
fi

# P2 散点: 禁止 bare except (防 静默吞噬 复发)
STAGED_PY_FILES=$(echo "$STAGED" | grep '\.py$' || true)
if [ -n "$STAGED_PY_FILES" ]; then
    BARE_EXCEPT=$(grep -nE '^\s*except\s*:\s*$' $STAGED_PY_FILES 2>/dev/null | head -5 || true)
    if [ -n "$BARE_EXCEPT" ]; then
        echo "❌ 检测到 bare except (P2 散点: 防 静默吞噬 复发)"
        echo "$BARE_EXCEPT" | head -5
        echo "   修复: 改 except Exception as e: + print/log, 或加 # noqa: BLE001"
        exit 1
    fi

    echo "Running ruff check (staged only)..."
    ruff check $STAGED_PY_FILES --quiet
    if [ $? -ne 0 ]; then
        echo ""
        echo "❌ Lint errors found. Fix them before committing."
        echo "   Run: ruff check . --fix"
        exit 1
    fi

    # B2 P0 根因预防 (FOLLOWUPS.md §B2): import 完整性检查
    # 扫 backend/ + scripts/etl/ 3rd-party imports, 跟 requirements.txt 对账
    # 根因: v0.4.7.3 → .3.2 链式 CI ImportError 修链
    echo "Running B2 import check..."
    if ! python3 .githooks/check_imports.py; then
        echo ""
        echo "❌ B2 import check failed — 修复:"
        echo "   1. 在 requirements.txt 加缺失的包"
        echo "   2. 重跑 commit"
        echo "   例外 (deps 故意未声明): git commit --no-verify"
        exit 1
    fi

    # B5 P2 test 顺序无关性 lint (FOLLOWUPS.md §B5)
    # 扫 backend/tests/ + tests/ 检测 N-index 断言, 警告但不阻断
    # 根因: v0.4.7.3.3 跨平台 flaky test (macOS extfs vs Linux ext4 glob 顺序)
    echo "Running B5 test order lint..."
    python3 .githooks/check_test_order.py || true  # WARN 不 fail, 让 user 看自己改

    # pytest cleanup orphans (v0.4.7) — moved to CI only for faster local commits
    # PYTHONPATH="$(pwd)" pytest backend/tests/test_wo_cleanup_orphans.py -q || exit 1

    echo "✅ Lint clean."
fi

# Sprint 3 P1-3: 拦截 docs/ review 风格输出中未附 git log 实证的 ground-truth 声明
# 教训: D-4 飞书架构 7 份刷出现 4 个 ground truth 错误, agent 凭 memory / stale 文档下结论
# 触发词: 未集成 / 不存在 / 占位 / TODO / FIXME / 缺失 / 待集成 / 还没接
# 证据模式: git log 命令 / 7-40 位 commit SHA / 已验证/已落地 等白名单词
# 范围: 仅 docs/ 下 .md, 排除 CHANGELOG.md / reference.md / DOCUMENT-INDEX.md
# 跳过: backend/ frontend-vue3/ scripts/ scraper/ 下的 code comment
# 救火: FQA_GROUND_TRUTH_SKIP=1 git commit ...
echo "Running P1-3 review ground-truth lint..."
python3 .githooks/check_review_ground_truth.py || exit 1

# Sprint 14 A.2: 改 backend/contracts/ 时必须同步更新 types.generated.ts
# 跟其他 lint 一样 WARN 模式不阻断 (codegen 需要 uvicorn 跑最新代码)
STAGED_CONTRACTS=$(echo "$STAGED" | grep -E '^backend/contracts/.*\.py$' || true)
if [ -n "$STAGED_CONTRACTS" ]; then
    echo ""
    echo "⚠️  Sprint 14 A.2: 改了 backend/contracts/ $(echo "$STAGED_CONTRACTS" | wc -l | tr -d ' ') 个文件"
    echo "   提醒: 跑 codegen 同步 frontend-vue3/src/api/types.generated.ts"
    echo "     1) 启 uvicorn 跑最新代码: PYTHONPATH=. nohup python3 -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 &"
    echo "     2) cd frontend-vue3 && npx openapi-typescript http://localhost:8000/openapi.json -o src/api/types.generated.ts"
    echo "   例外 (不打算同步前端): git commit --no-verify"
    # 不阻断, 只 WARN
fi

# Sprint 14 教训: 改 frontend-vue3/src/ 时强制 vue-tsc 真编译 (Sprint 14 f72cbe3/1126957/ba745ca
# 3 次 commit 漏错, 因为 vitest 不 import AudienceView 模板, 只跑 vue-tsc 才发现
# 'const v = row.const v = row.X' 语法错). 阻断, 不许 --no-verify 跳过.
STAGED_VUE=$(echo "$STAGED" | grep -E '^frontend-vue3/src/.*\.(vue|ts)$' || true)
if [ -n "$STAGED_VUE" ]; then
    echo ""
    echo "Running vue-tsc --noEmit (Sprint 14 教训, 强制真编译 .vue 模板)..."
    cd frontend-vue3 && npx vue-tsc --noEmit -p . 2>&1 | tail -20
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo ""
        echo "❌ vue-tsc 失败 — 修复语法/类型错后再 commit"
        echo "   例外 (紧急 hotfix): git commit --no-verify"
        exit 1
    fi
    cd ..
fi

# Sprint 33 候选 1: .vue/.ts 结构 sanity check + vite build (防 a9b1d91 类 .vue 误清空)
# 教训: a9b1d91 commit (2026-06-13) 误清空 SamplingView.vue (32653 字节 → 699 字节, 699 个 newline),
#       5+ 天未发现. 验证发现 (Sprint 33.1 实施时):
#       - vue-tsc --noEmit 不报 (空 .vue 文件结构合法, vue-tsc 跳过未引用的 .vue)
#       - vite build lazy load 跳过未引用的 .vue (a9b1d91 SamplingView 在 router 里但 build OK,
#         原因是当前 Vite 版本对空 SFC (newline-only) 兼容, 不报 'At least one <template>'
#       - 真正捕获 a9b1d91 类事故的 = 访问路由触发实际编译 (候选 3 e2e 11 view 治根)
# 本 hook 提供 P1 防御性:
#   (a) grep sanity check: 任何 .vue 必须含 <template 或 <script 标记, 直接拦截整文件清空
#   (b) vite build: 兜底未来 Vite 升级回归 + 引用 .vue 的真实结构性破坏
# 成本: grep < 100ms + vite build ~1s (981ms baseline) = ~1.1s/commit
STAGED_VUE_FILES=$(echo "$STAGED" | grep -E '^frontend-vue3/src/.*\.vue$' || true)
if [ -n "$STAGED_VUE_FILES" ]; then
    echo ""
    echo "Running .vue structure sanity check (Sprint 33 候选 1a, grep <template|<script)..."
    for f in $STAGED_VUE_FILES; do
        if [ -f "$f" ] && ! grep -qE '<template|<script' "$f"; then
            echo ""
            echo "❌ $f 缺 <template>/<script> 标记 — 防 a9b1d91 类整文件清空"
            echo "   文件大小: $(wc -c < "$f" | tr -d ' ') bytes"
            echo "   Sprint 32.3 教训: a9b1d91 commit 误清空 SamplingView.vue (32653→699 字节), 5+ 天未发现"
            echo "   修复: 还原 .vue 文件或 git restore --staged $f"
            echo "   例外 (紧急 hotfix): git commit --no-verify"
            exit 1
        fi
    done
fi

STAGED_VUE_BUILD=$(echo "$STAGED" | grep -E '^frontend-vue3/src/.*\.(vue|ts)$' || true)
if [ -n "$STAGED_VUE_BUILD" ]; then
    echo ""
    echo "Running npx vite build (Sprint 33 候选 1b, 兜底未来 Vite 升级回归 + 引用 .vue 错)..."
    cd frontend-vue3 && npx vite build 2>&1 | tail -20
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo ""
        echo "❌ vite build 失败 — 引用 .vue/.ts 文件结构性破坏"
        echo "   修复: 检查 commit diff 中被引用的 .vue/.ts 文件结构"
        echo "   例外 (紧急 hotfix): git commit --no-verify"
        exit 1
    fi
    cd ..
fi
