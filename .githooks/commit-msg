#!/usr/bin/env bash
# Sprint 58 #2 阶段 A: commit-msg blocking hook 模板 (默认不启用).
# Phase B 升级时, 直接复制此文件到 .githooks/commit-msg 覆盖现有 WARN hook.

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ "$#" -lt 1 ]; then
    echo "Usage: commit-msg <commit_msg_file>" >&2
    exit 2
fi

python3 "$PROJECT_ROOT/scripts/commit_msg_check.py" "$1"
EXIT_CODE=$?

if [ "$EXIT_CODE" -eq 1 ]; then
    echo ""
    echo "❌ commit-msg drift 检测失败, commit 被阻止 (Sprint 58 #2)"
    echo ""
    echo "修复方法:"
    echo "1. 把 commit msg 写得更具体"
    echo "2. 或在紧急 hotfix 时使用 git commit --no-verify"
    echo ""
    exit 1
fi

exit "$EXIT_CODE"

# ## Stage 2 完成 — Sprint 58 #2 阶段 A
# - 备用 blocking hook 模板已准备好, Phase B 复制到 `.githooks/commit-msg` 即可启用.
# - 阶段 A 不修改现有 `.githooks/commit-msg` 与 `.githooks/pre-commit`.
