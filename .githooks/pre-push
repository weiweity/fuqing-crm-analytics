#!/bin/bash
# Pre-push hook: run tests before pushing to remote
# Install: git config core.hooksPath .githooks
# Slow tests (DuckDB integration) run in CI only.

# Sprint 38 race flake 治标: 检测 uvicorn 是否占 DuckDB fd, 跑批前 warn user.
# 真连 test (test_churn_user_list_fstring / test_w4_t7_integration) 会自己 skip
# (test_churn_user_list_fstring.py:55,77 + test_w4_t7_integration.py:147,181,197,228
#  + test_w4_full.py:319 等的 _IN_XDIST_PARALLEL / skip_if_duckdb_locked), 但 push
# 时间应该让 user 知道 race flake 现状 (5 sprint 复发 Sprint 32.3/34.1/36-1/37/38).
# 真治本留 Sprint 36.x+ (per-test tmp DuckDB ATTACH 模式, Sprint 38 调研 ROI 低).
_UVICORN_PID=$(lsof -nP -iTCP:8000 -sTCP:LISTEN -t 2>/dev/null | head -1)
if [ -n "$_UVICORN_PID" ]; then
    echo "⚠️  uvicorn PID $_UVICORN_PID 跑着, race flake 真连 test 会自动 skip (DuckDB 文件锁 exclusive)."
    echo "   Sprint 38 治标: 0 flake, 但真连接 integration test 跳过."
    echo "   真跑真连 test: kill $_UVICORN_PID 后重跑, 或用 pytest -n0 serial mode."
fi

echo "Running tests before push (parallel, excluding slow)..."
# Sprint 108 必修 3 L4.7 实战 fix 模式: 改 -n auto (parallel) → -n0 (serial).
# xdist parallel pytest 触发 dotenv main.py:358 FileNotFoundError (跟 Sprint 38 race flake 治标同模式).
# 跟 Sprint 38 治标尾声 + 必修 1 load_dotenv FileNotFoundError 兜底 配套.
PYTHONPATH="$(git rev-parse --show-toplevel)" python3 -m pytest backend/tests/ -x -q -n0 -m "not slow" 2>/dev/null
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Tests failed. Fix them before pushing."
    echo "   Run: PYTHONPATH=. pytest backend/tests/ -x -q"
    echo "   Full suite (including slow): PYTHONPATH=. pytest backend/tests/ -x -q -n auto"
    exit 1
fi

echo "✅ Tests passed. (slow tests run in CI)"
# Sprint 38 race flake 治标尾声: 提示 user 已 skip 的真连 test, 提醒真跑模式.
echo "📋 真连 test (DuckDB): 跑 `kill \$_UVICORN_PID && pytest backend/tests/test_churn_user_list_fstring.py -v -n0` 真验证回归."
