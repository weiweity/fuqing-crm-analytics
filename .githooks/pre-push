#!/bin/bash
# Pre-push hook: smart path + C-class deselect SSOT
# Install: git config core.hooksPath .githooks
#
# Track A 2026-07-19:
#   - deselect SSOT: scripts/ci/pytest_c_class_deselects.txt (shared with lint/nightly)
#   - smart path:
#       skip  → docs/md/changelog/handoff only
#       ruff  → scripts/hooks only → ruff check backend/
#       full  → backend tests/services/routers/middleware/db/main + requirements
#
# Slow tests (DuckDB integration) run in CI only.

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

ZERO="0000000000000000000000000000000000000000"
CLASSIFIER="$REPO_ROOT/scripts/ci/pre_push_path_class.py"
DESELECT_SH="$REPO_ROOT/scripts/ci/pytest_deselect_args.sh"

# Collect changed files from stdin push refs (git pre-push protocol)
CHANGED_FILES=""
while read -r local_ref local_sha remote_ref remote_sha; do
    # branch delete → no tests
    if [ "$local_sha" = "$ZERO" ]; then
        continue
    fi
    if [ "$remote_sha" = "$ZERO" ]; then
        # new branch: diff vs merge-base with main/origin/main
        base=""
        if git rev-parse --verify origin/main >/dev/null 2>&1; then
            base="$(git merge-base origin/main "$local_sha" 2>/dev/null || true)"
        fi
        if [ -z "$base" ] && git rev-parse --verify main >/dev/null 2>&1; then
            base="$(git merge-base main "$local_sha" 2>/dev/null || true)"
        fi
        if [ -n "$base" ]; then
            CHANGED_FILES="${CHANGED_FILES}
$(git diff --name-only "$base" "$local_sha" 2>/dev/null || true)"
        else
            # fallback: all files in the tip commit tree vs empty → force full
            CHANGED_FILES="${CHANGED_FILES}
backend/main.py"
        fi
    else
        CHANGED_FILES="${CHANGED_FILES}
$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null || true)"
    fi
done

# If stdin empty (manual hook run), fall back to origin/main...HEAD or @{u}
if [ -z "$(echo "$CHANGED_FILES" | tr -d '[:space:]')" ]; then
    if git rev-parse --verify origin/main >/dev/null 2>&1; then
        CHANGED_FILES="$(git diff --name-only origin/main...HEAD 2>/dev/null || true)"
    elif git rev-parse --verify @{u} >/dev/null 2>&1; then
        CHANGED_FILES="$(git diff --name-only @{u}...HEAD 2>/dev/null || true)"
    else
        CHANGED_FILES="backend/main.py"
    fi
fi

MODE="$(printf '%s\n' "$CHANGED_FILES" | python3 "$CLASSIFIER" --files-from - 2>/dev/null || echo full)"

echo "pre-push smart path mode: $MODE"

case "$MODE" in
    skip)
        echo "✅ Docs/md/changelog/handoff only (or frontend-only) — skip full pytest."
        echo "   Changed sample:"
        printf '%s\n' "$CHANGED_FILES" | sed '/^$/d' | head -10 | sed 's/^/   - /'
        exit 0
        ;;
    ruff)
        echo "Running ruff check backend/ (scripts/hooks-only path, skip full pytest)..."
        if command -v ruff >/dev/null 2>&1; then
            ruff check backend/
        else
            python3 -m ruff check backend/
        fi
        if [ $? -ne 0 ]; then
            echo ""
            echo "❌ ruff failed. Fix before pushing."
            exit 1
        fi
        echo "✅ ruff passed. Full pytest skipped (no backend tests/services/routers/db/main touched)."
        exit 0
        ;;
    full|*)
        # fall through to full pytest
        ;;
esac

# --- full path: uvicorn race warn + pytest with deselect SSOT ---

# Sprint 38 race flake 治标: 检测 uvicorn 是否占 DuckDB fd
_UVICORN_PID=$(lsof -nP -iTCP:8000 -sTCP:LISTEN -t 2>/dev/null | head -1)
if [ -n "$_UVICORN_PID" ]; then
    echo "⚠️  uvicorn PID $_UVICORN_PID 跑着, race flake 真连 test 会自动 skip (DuckDB 文件锁 exclusive)."
    echo "   Sprint 38 治标: 0 flake, 但真连接 integration test 跳过."
    echo "   真跑真连 test: kill $_UVICORN_PID 后重跑, 或用 pytest -n0 serial mode."
fi

echo "Running full pytest before push (serial -n0, C-class deselect SSOT)..."

# Build --deselect args from SSOT (7 C-class nodeids)
DESELECT_ARGS=()
if [ -x "$DESELECT_SH" ] || [ -f "$DESELECT_SH" ]; then
    while IFS= read -r tok; do
        [ -n "$tok" ] && DESELECT_ARGS+=("$tok")
    done < <(bash "$DESELECT_SH")
else
    echo "ERROR: missing $DESELECT_SH" >&2
    exit 1
fi

PYTHONPATH="$REPO_ROOT" python3 -m pytest backend/tests/ -x -q -n0 -m "not slow" \
  "${DESELECT_ARGS[@]}" 2>/dev/null
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Tests failed. Fix them before pushing."
    echo "   Run: PYTHONPATH=. pytest backend/tests/ -x -q"
    echo "   Deselect SSOT: scripts/ci/pytest_c_class_deselects.txt"
    echo "   Full suite (including slow): PYTHONPATH=. pytest backend/tests/ -x -q -n auto"
    exit 1
fi

echo "✅ Tests passed. (slow tests run in CI; C-class deselect from SSOT)"
echo "📋 真连 test (DuckDB): 跑 kill \$_UVICORN_PID && pytest backend/tests/test_churn_user_list_fstring.py -v -n0 真验证回归."
