# DMP Scraper 环境变量模板
# 用法：cp scraper/.env.example scraper/.env，填入实际值
# 实际加载：scraper/core/sanity_check.py 通过 os.environ 读取
# （如需 dotenv 自动加载，请在调用前自行 source .env 或用 python-dotenv）

# ============================================================
# lark-cli 告警（私聊推送，替代原飞书 webhook）
# ============================================================
# 6 道门禁（sanity_check.py）任一失败 → 调 lark-cli subprocess 推 lark-cli 私聊
# 未配置时静默跳过告警（不报错，graceful degrade）
#
# 优势 vs 飞书 webhook：
#   - 无需创建群、添加机器人、复制 webhook URL
#   - 直接发私聊（任何 user open_id），更快调试
#   - 支持 text/markdown/post/image/file/media 全格式
#   - 单测 mock 简单（mock subprocess.run）
#
# 配置步骤：
#   1. 安装 lark-cli：brew install lark-cli（已安装则跳过）
#   2. lark-cli 登录：lark-cli login（按提示完成 OAuth，app secret 存 keychain）
#   3. 找收件人 open_id：
#        lark-cli contact +search-user --query "收件人姓名" --as user
#      或自己：cat ~/.lark-cli/config.json → apps[].users[].userOpenId
#   4. 测试：
#        lark-cli im +messages-send --user-id "ou_xxx" --text "test" --as bot
#   5. 填入下方 LARK_OPEN_ID
#   6. 端到端：python3 -c "from scraper.core import sanity_check; print(sanity_check._send_lark_alert('test'))"
#
# 可选：自定义 lark-cli 路径（默认 /Users/hutou/homebrew/bin/lark-cli）
LARK_OPEN_ID=ou_2f9424ec9e4f74b3af50d94096ba7623
# LARK_BIN=/Users/hutou/homebrew/bin/lark-cli
