# ─────────────────────────────────────────────────────────────
# 芙清 CRM - Git 忽略文件
# 数据 / 缓存 / 依赖 / 环境变量 / 构建产物
# ─────────────────────────────────────────────────────────────

# 数据文件（核心：绝不能提交真实客户数据）
data/
*.duckdb
*.duckdb.backup*
*.duckdb.bak*
*.xlsx
*.csv
*.zip

# 例外：ETL perf baseline（QW0 工单 0，plan §A4.1 强制入仓）
# 父目录链必须逐级例外化，否则 git 不会重新包含被 data/ 排除的子目录
!data/
!data/processed/
!data/processed/etl_perf/
!data/processed/etl_perf/*.json

# 环境变量（路径配置、API Keys）
.env
.env.local
.env.*.local

# Python 缓存 & 虚拟环境
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
.pytest_cache/

# 前端依赖 & 构建产物
node_modules/
frontend-vue3/node_modules/
frontend-vue3/dist/

# IDE / 系统文件
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log
nohup.out

# Playwright
frontend-vue3/test-results/
frontend-vue3/playwright-report/

# 测试覆盖率
.coverage
htmlcov/

# 运行时缓存
backend/cache/

# 健康评分配置备份（API 自动生成，不进版本控制）
config/health_config_backups/

# 企业知识库 / 设计审计（大文件/内部资料，不纳入版本控制）
docs/business/业务知识/
docs/campaigns/618-breakdown/
designs/

# 工作空间 / 工具配置（不上传）
.workbuddy/
.gstack/
.codebuddy/
.context/

# 归档目录（历史文档/脚本，不再维护）
docs/archive/
scripts/archive/

# 分析报告（临时生成，不进版本控制）
docs/reports/

# UV 锁文件（可选，如果不用 uv 管理依赖）
# uv.lock
