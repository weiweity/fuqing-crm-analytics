# ─────────────────────────────────────────────────────────────
# 芙清 CRM - Git 忽略文件
# 数据 / 缓存 / 依赖 / 环境变量 / 构建产物
# ─────────────────────────────────────────────────────────────

# 数据文件（核心：绝不能提交真实客户数据）
data/
*.duckdb
*.duckdb.backup*
*.duckdb.bak*
*.xlsx
*.csv
*.zip

# 环境变量（路径配置、API Keys）
.env
.env.local
.env.*.local

# Python 缓存 & 虚拟环境
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
.pytest_cache/

# 前端依赖 & 构建产物
node_modules/
frontend-vue3/node_modules/
frontend-vue3/dist/

# IDE / 系统文件
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log
nohup.out

# Playwright
frontend-vue3/test-results/
frontend-vue3/playwright-report/

# 测试覆盖率
.coverage
htmlcov/

# 运行时缓存
backend/cache/

# 工作空间 / 工具配置（不上传）
.workbuddy/
.gstack/
.codebuddy/
