# ─────────────────────────────────────────────────────────────
# 芙清 CRM - Git 忽略文件
# 数据 / 缓存 / 依赖 / 环境变量 / 构建产物
# ─────────────────────────────────────────────────────────────

# 数据文件（核心：绝不能提交真实客户数据）
data/
*.duckdb
*.duckdb.backup*
*.duckdb.bak*
*.xlsx
*.csv
*.zip

# 例外：ETL perf baseline（QW0 §A4.1 首次入仓 baseline, Sprint 22+ 漂移不入仓）
# baseline JSON 是 ETL 跑批运行时 auto-drift 产物 (每次 run_etl.py --update 重写)
# 首次 baseline 入仓作为参考基线; 后续漂移不入仓避免 git log 噪声 + merge conflict
# 父目录链必须逐级例外化（不要写 !data/，会把 data/ 全部重新包含进来）
!data/processed/etl_perf/
!data/processed/etl_perf/*.json

# 例外：docs/data/data-layout.md 是文档不是数据（git `data/` 模式会匹配 docs/data/）
# 注：docs/data/ 子目录仅文档，不放运行时数据。运行时数据归 data/（排除）
!docs/data/
!docs/data/data-layout.md

# 环境变量（路径配置、API Keys）
.env
.env.local
.env.*.local

# Python 缓存 & 虚拟环境
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
.pytest_cache/

# 前端依赖 & 构建产物
node_modules/
frontend-vue3/node_modules/
frontend-vue3/dist/

# IDE / 系统文件
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log
nohup.out

# Playwright
frontend-vue3/test-results/
frontend-vue3/playwright-report/

# 测试覆盖率
.coverage
htmlcov/

# 运行时缓存
backend/cache/

# 健康评分配置备份（API 自动生成，不进版本控制）
config/health_config_backups/

# 企业知识库 / 设计审计（大文件/内部资料，不纳入版本控制）
docs/business/业务知识/
docs/campaigns/618-breakdown/
designs/

# 工作空间 / 工具配置（不上传）
.workbuddy/
.gstack/
.codebuddy/
.context/
.claude/
.codegraph/

# Codex app 自动 init 文件 (不污染主仓, Codex 启动会重新 init)
# Sprint 43.1 后跟 Codex app 协作, Codex 自动创建 AGENTS.md / .codex/ / .agents/
# 主仓用 HANDOFF.md (Claude) + HANDOFF-TO-CODEX.md (Stage 1 输出) 代替
.agents/
.codex/
AGENTS.md

# Sprint 22.5+ claude-automation-recommender 落地 (跟 data/processed/etl_perf/ precedent 一致):
# .claude/ 例外化让 settings.json (3 hooks) + skills/ (regen-types, ship-pr) 入仓, 团队共享.
# 父目录链必须逐级例外化（不要写 !.claude/，会把 .claude/ 全部重新包含进来）
!.claude/settings.json
!.claude/skills/
!.claude/skills/*/
!.claude/skills/*/SKILL.md

# 一次性维护脚本（本地保留作工具，按脚本文件头自述"不入 git"）
scripts/etl/_cleanup_staging.py

# 归档目录（历史文档/脚本，不再维护）
docs/archive/
scripts/archive/

# 分析报告（临时生成，不进版本控制）
docs/reports/

# UV 锁文件（可选，如果不用 uv 管理依赖）
# uv.lock

# Sprint 5 #20 (P0) — 主项目根 scraper/ 软删 + symlink (v0.4.14.46)
# 修复 f16b947 漏做: 真正 git rm scraper/ (31 tracked files) + ln -s → 独立 repo fuqing-scraper
# scraper.legacy/ 是 521M 软删备份 (1-3 天观察期后处置 Sprint 5+)
# scraper 自身是 symlink → /Users/hutou/Desktop/fuqin date/fuqing-scraper (不进 git, OS 跟踪)
scraper.legacy/
/scraper
