# 芙清 CRM - 环境变量模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ============================================================
# 数据源路径（Mac 开发环境示例）
# ============================================================
SHOP_DATA_SOURCE=/Users/yourname/Desktop/fuqin-date/芙清CRM数据库
MEMBER_DATA_SOURCE=/Users/yourname/Desktop/fuqin-date/芙清CRM数据库

# ============================================================
# ETL 配置
# ============================================================
SPU_MAPPING_SOURCE=config/spu_mapping.xlsx
CHANNEL_RULES_SOURCE=config/channel_rules.xlsx
TAOKE_DATA_SOURCE=/path/to/taoke/data
TAOKE_PRODUCT_SOURCE=/path/to/taoke/product
LIVE_DATA_SOURCE=/path/to/live/data

# ============================================================
# 数据库
# ============================================================
DUCKDB_PATH=data/processed/fuqing.duckdb
PROCESSED_DATA_DIR=data/processed
PARQUET_DATA_DIR=data/parquet

# ============================================================
# Lark 通知（W6: ETL 跑完 lark-cli 推老板 + 运营）
# ============================================================
# 复用 scraper/core/sanity_check.py::_send_lark_alert 通道（lark-cli 私聊）
# NOTIFY_OPEN_IDS: 逗号分隔收件人 open_id 列表（ETL 跑完推给老板 + 运营）
#                  未配置/空 = 跳过通知（不报错，graceful degrade）
# LARK_BIN: lark-cli 路径（默认 /Users/hutou/homebrew/bin/lark-cli）
# LARK_OPEN_ID: _send_lark_alert 单收件人 fallback（W6 走 NOTIFY_OPEN_IDS 不读它；
#              scraper 6 道门禁告警单收件人走这个）
NOTIFY_OPEN_IDS=ou_boss123,ou_op456
LARK_BIN=/Users/hutou/homebrew/bin/lark-cli
LARK_OPEN_ID=ou_boss123

# ============================================================
# API 安全
# ============================================================
HEALTH_API_KEY=your-secret-key-here

# ============================================================
# 前端
# ============================================================
VITE_API_BASE_URL=http://localhost:8001
