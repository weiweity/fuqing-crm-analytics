# 芙清 CRM - 环境变量模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ============================================================
# 数据源路径（Mac 开发环境示例）
# ============================================================
SHOP_DATA_SOURCE=/Users/yourname/Desktop/fuqin date/芙清CRM数据库
MEMBER_DATA_SOURCE=/Users/yourname/Desktop/fuqin date/芙清CRM数据库

# ============================================================
# ETL 配置
# ============================================================
SPU_MAPPING_SOURCE=config/spu_mapping.xlsx
CHANNEL_RULES_SOURCE=config/channel_rules.xlsx
TAOKE_DATA_SOURCE=/path/to/taoke/data
TAOKE_PRODUCT_SOURCE=/path/to/taoke/product
LIVE_DATA_SOURCE=/path/to/live/data

# ============================================================
# 数据库
# ============================================================
DUCKDB_PATH=data/processed/fuqing.duckdb
PROCESSED_DATA_DIR=data/processed
PARQUET_DATA_DIR=data/parquet

# ============================================================
# API 安全
# ============================================================
HEALTH_API_KEY=your-secret-key-here

# ============================================================
# 前端
# ============================================================
VITE_API_BASE_URL=http://localhost:8001
