# ─────────────────────────────────────────────────────────────
# 芙清 CRM - 环境变量模板
# 复制此文件为 .env 并填入你的本地路径
# ─────────────────────────────────────────────────────────────

# 原始数据根目录（店铺数据库、会员数据库、SPU 匹配表等）
# 请修改为你的实际路径
SHOP_DATA_SOURCE=/path/to/your/店铺数据库
MEMBER_DATA_SOURCE=/path/to/your/会员数据库
SPU_MAPPING_SOURCE=/path/to/your/天猫_spu单品匹配表_数据表.csv
SHOP_STATUS_SOURCE=/path/to/your/订单状态刷新
VISITOR_DATA_SOURCE=/path/to/your/店铺流量数据库
CAMPAIGN_SCHEDULE_SOURCE=/path/to/your/芙清全年平台活动节奏 - Sheet2.csv

# DMP 数据目录（可选，仅市场对焦模块需要）
DMP_DATA_DIR=/path/to/your/DMP_test_package/core

# DuckDB 数据库路径（默认使用项目内 data/processed/ 目录）
# DUCKDB_PATH=/path/to/your/fuqing_crm.duckdb

# API 安全密钥（启动后端时自动生成，也可手动设置）
# HEALTH_API_KEY=your-secret-key-here
