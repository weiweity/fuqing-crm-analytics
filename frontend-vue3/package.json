{
  "name": "frontend-vue3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "gen:types": "openapi-typescript $API_URL -o src/api/types.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint:spec": "bash e2e/lint/spec-lint-l2.sh e2e"
  },
  "dependencies": {
    "@rive-app/canvas": "^2.37.5",
    "@tanstack/vue-query": "^5.99.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.0",
    "echarts": "^6.0.0",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.2.6"
  }
}
